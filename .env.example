# ── Notion ───────────────────────────────────────────────────────────────────
# Clé d'intégration interne Notion (notion.so/profile/integrations → format ntn_…)
# L'intégration doit avoir accès à la base (••• → Connections sur la page Notion).
# Sans cette clé, l'app sert un jeu de données de démonstration.
NOTION_API_KEY=
NOTION_DATABASE_ID=3761a4a44e9681698138cbf5e1d0c090
# Optionnel : ID de la data source (API Notion 2025-09-03 / SDK v5). Si vide,
# il est résolu automatiquement depuis la base. Valeur connue pour cette base :
# NOTION_DATA_SOURCE_ID=3761a4a4-4e96-8182-9f6b-000bdbf593b7

# ── Anthropic (chat) ─────────────────────────────────────────────────────────
# Sans cette clé, le chat utilise un moteur de réponses local (parité prototype).
ANTHROPIC_API_KEY=

# ── Optionnel : protection d'accès (V2) ──────────────────────────────────────
# DASHBOARD_PASSWORD=
